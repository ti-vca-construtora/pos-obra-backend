generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nome      String?
  cpf       String?  @unique
  birthDate String?
  role      String   @default("ADMIN")
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("usuario")
}

model Example {
  id        Int      @id @default(autoincrement())
  title     String
  filePath  String?
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("example")
}

model Motivo {
  id        Int      @id @default(autoincrement())
  descricao String
  status    Boolean  @default(true)

  createdAt DateTime @default(now())

  @@map("motivo")
}

model Grupo {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  status    Boolean  @default(true)

  subgrupos Subgrupo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("grupo")
}

model Subgrupo {
  id       Int     @id @default(autoincrement())
  nome     String  @unique
  status   Boolean @default(true)

  emergencia Boolean @default(false)

  grupoId  Int
  grupo    Grupo   @relation(fields: [grupoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([grupoId])
  @@map("subgrupo")
}

model AtendimentoMobuss {
  id               String   @id @default(uuid())
  idMobuss         String   @unique
  numSolicitacao   String?

  cpfCnpjCliente   String
  nomeSolicitante  String?
  emailSolicitante String?

  status           String

  payloadEnvio     Json
  payloadResposta  Json?

  agendamento      AgendamentoMobuss?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([cpfCnpjCliente])
  @@map("atendimentomobuss")
}

model AgendamentoMobuss {
  id               String   @id @default(uuid())
  idVisita         String   @unique

  dataInicio       DateTime
  dataFim          DateTime
  idColaborador    String

  atendimentoId    String   @unique
  atendimento      AtendimentoMobuss @relation(fields: [atendimentoId], references: [id])

  payloadEnvio     Json
  payloadResposta  Json?

  createdAt        DateTime @default(now())

  @@map("agendamentomobuss")
}

model PasswordReset {
  id        String   @id @default(uuid())

  email     String
  token     String

  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset")
}

model EmpreendimentoMobuss {
  id           String   @id @default(uuid())

  idMobuss     String   @unique
  nome         String

  manualUrl    String?  // link do manual (opcional)

  ativo        Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([idMobuss])
  @@map("empreendimentomobuss")
}

model TermoSite {

  id        Int      @id @default(1)

  conteudo  String   @db.LongText

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("termosite")

}

model AvisoSite {

  id          String   @id @default(uuid())

  titulo      String
  descricao   String   @db.LongText

  ativo       Boolean  @default(false)

  dataInicio  DateTime
  dataFim     DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ativo])
  @@index([dataInicio, dataFim])

  @@map("avisosite")

}
